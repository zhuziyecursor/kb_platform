# =============================================================================
# 企业 AI 知识库 - Docker Compose 环境变量配置
# =============================================================================
# 复制此文件为 .env 后按需修改：
#   cp .env.example .env
#
# 应用服务使用 KB_ 前缀的环境变量（见各服务的 config/settings.yaml 或 application.yml）
# 基础设施服务使用原始名称（PostgreSQL, Redis, MinIO 等）
# =============================================================================

# --------------------------- 基础设施端口 ------------------------------------
POSTGRES_PORT=25432
REDIS_PORT=26379
MINIO_API_PORT=29000
MINIO_CONSOLE_PORT=29001
KAFKA_PORT=9092
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
TIKA_PORT=29998
KAFKA_UI_PORT=28090
LOKI_PORT=31008
GRAFANA_PORT=31009

# --------------------------- PostgreSQL 配置 ---------------------------------
POSTGRES_USER=kb_admin
POSTGRES_PASSWORD=kb_postgres_dev
POSTGRES_DB=kb_knowledge

# --------------------------- Redis 配置 --------------------------------------
REDIS_PASSWORD=kb_redis_dev_2026

# --------------------------- MinIO 配置（业务存储）----------------------------
MINIO_ROOT_USER=kb_minio_admin
MINIO_ROOT_PASSWORD=kb_minio_dev_2026

# --------------------------- 外部服务 ----------------------------------------
# BGE-M3 Embedding 服务地址
KB_EMBEDDING_SERVICE_URL=http://192.168.30.47:31296

# MiniMax LLM API Key (必填 — 用于 LLM 切片精修和 llm-gateway)
MINIMAX_API_KEY=your_minimax_api_key_here
