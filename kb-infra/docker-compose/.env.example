# =============================================================================
# 企业 AI 知识库 - Docker Compose 环境变量配置
# =============================================================================
# 复制此文件为 .env 后按需修改：
#   cp .env.example .env
#
# 应用服务使用 KB_ 前缀的环境变量（见各服务的 config/settings.yaml 或 application.yml）
# 基础设施服务使用原始名称（PostgreSQL, Redis, MinIO 等）
# =============================================================================

# ============== 基础设施服务端口 ==============
POSTGRES_PORT=25432
REDIS_PORT=26379
MINIO_API_PORT=29000
MINIO_CONSOLE_PORT=29001
KAFKA_PORT=9092
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
TIKA_PORT=29998
KAFKA_UI_PORT=28090

# ============== PostgreSQL 配置 ==============
POSTGRES_USER=kb_admin
POSTGRES_PASSWORD=kb_postgres_dev
POSTGRES_DB=kb_knowledge

# ============== Redis 配置 ==============
REDIS_PASSWORD=kb_redis_dev

# ============== MinIO 配置（业务存储）==============
MINIO_ROOT_USER=kb_minio_admin
MINIO_ROOT_PASSWORD=kb_minio_dev_2026

# ============== Kafka 配置 ==============
# KAFKA_CFG_ADVERTISED_LISTENERS 配置了 localhost:29092 供宿主机访问
